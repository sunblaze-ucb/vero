            "spec_create_exists",
            "spec_close_removes",
            "spec_close_preserves_others"
          ]
        },
        {
          "name": "Transaction",
          "impl": "BankLedger/Impl/Transaction.lean",
          "spec": "BankLedger/Spec/Transaction.lean",
          "apis": [
            {"name": "deposit",  "sig": "DepositSig",  "type": "AccountId → Balance → Ledger → Option Ledger"},
            {"name": "withdraw", "sig": "WithdrawSig", "type": "AccountId → Balance → Ledger → Option Ledger"}
