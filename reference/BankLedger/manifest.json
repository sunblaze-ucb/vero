          "apis": [
            {"name": "transfer", "sig": "TransferSig", "type": "AccountId → AccountId → Balance → Ledger → Option Ledger"}
          ],
          "specs": ["spec_transfer_preserves_total", "spec_transfer_updates_both"]
        },
        {
          "name": "Ledger",
          "impl": "BankLedger/Impl/Ledger.lean",
          "spec": "BankLedger/Spec/Ledger.lean",
          "apis": [
            {"name": "totalAssets", "sig": "TotalAssetsSig", "type": "Ledger → Balance"},
            {"name": "accountList", "sig": "AccountListSig", "type": "Ledger → List AccountId"},
            {"name": "numAccounts", "sig": "NumAccountsSig", "type": "Ledger → Nat"}
          ],
          "specs": ["spec_total_create_invariant", "spec_num_matches_list"]
