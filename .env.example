# vero credentials. Copy to `.env` and fill in keys for the agent(s) you use.
#
#   cp .env.example .env
#
# The active credentials profile is chosen on the command line with
# `credentials=<profile>` (default: `litellm`). Each profile reads a different
# subset of the variables below, so you only need the ones your profile uses.
# See docs/agents.md for the full matrix.

# ─────────────────────────────────────────────────────────────────────────
# Default profile: litellm  (one key/base feeds both the Claude and Codex agents)
#   vero run ... credentials=litellm      # default, may be omitted
# ─────────────────────────────────────────────────────────────────────────
LLM_API_KEY=
LLM_API_BASE=

# Optional per-agent overrides (split billing / different endpoints).
# Claude agent (Claude Agent SDK):
CLAUDE_AGENT_API_KEY=
CLAUDE_AGENT_API_BASE=
# Codex agent (`codex exec` CLI):
CODEX_AGENT_API_KEY=
CODEX_AGENT_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────
# Provider-direct profiles (use instead of litellm)
# ─────────────────────────────────────────────────────────────────────────
# credentials=anthropic
ANTHROPIC_API_KEY=
# credentials=openai
OPENAI_API_KEY=
# credentials=openrouter   (routes both agents through OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────────────────────
# Point the harness at a specific env file (default: the repo-root .env)
# VERO_ENV_FILE=
